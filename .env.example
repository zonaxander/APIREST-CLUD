# Copia este archivo a ".env" y completa con tus datos reales
PORT=3000

# OPCION A: si tu proveedor (Railway, Render, Supabase, Neon...) te da una
# sola cadena de conexion, pegala aqui y deja las variables PG* de abajo vacias.
# DATABASE_URL=postgresql://usuario:clave@host:5432/nombre_basedatos

# OPCION B: variables sueltas (uso tipico en local)
PGHOST=localhost
PGPORT=5432
PGDATABASE=gestor_herramientas
PGUSER=postgres
PGPASSWORD=cambia_esta_clave

# "true" fuerza SSL, "false" lo apaga, y si lo dejas vacio se activa solo
# cuando usas DATABASE_URL o NODE_ENV=production
PGSSL=
